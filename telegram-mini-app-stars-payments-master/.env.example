# Telegram Bot Token (get from @BotFather on Telegram)
BOT_TOKEN=your_bot_token_here

# PostgreSQL connection string (for Vercel, use Neon/Serverless Postgres)
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/sales_db

# Optional: Custom item secret codes (JSON format)
# If not set, defaults will be used
ITEM_SECRETS={"ice_cream":"FROZEN2025","cookie":"SWEET2025","hamburger":"BURGER2025"}

# Webhook URL for Telegram bot updates
# After deploying, set this via:
# https://api.telegram.org/bot<BOT_TOKEN>/setWebhook?url=<YOUR_DEPLOYED_URL>/api/webhook
